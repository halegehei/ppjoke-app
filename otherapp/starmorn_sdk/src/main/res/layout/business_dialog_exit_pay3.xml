<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <LinearLayout
        android:id="@+id/outRootLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical">
        
        <ImageView
            android:id="@+id/closeBtn"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="end"
            android:layout_marginEnd="20dp"
            android:src="@mipmap/business_pay3_exit_dialog_close_bg"/>

        <RelativeLayout
            android:id="@+id/rootLayout"
            android:layout_width="271dp"
            android:layout_height="406dp"
            android:layout_gravity="center_horizontal">

            <ImageView
                android:id="@+id/loadImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@mipmap/business_test_pay3_dialog_bg"/>

            <TextView
                android:id="@+id/topLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="topLabel"
                android:textColor="@color/white"
                android:textSize="16dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="14dp"
                android:shadowRadius="3"
                android:shadowColor="#4D6D1004"
                android:shadowDx="3"
                android:shadowDy="3"/>

            <TextView
                android:id="@+id/freeDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="99"
                android:textColor="#FF4048"
                android:textSize="30dp"
                android:layout_marginTop="95dp"
                android:includeFontPadding="false"
                android:layout_marginStart="140dp"
                android:shadowRadius="3"
                android:shadowColor="#006D1004"
                android:shadowDx="3"
                android:textStyle="italic|bold"
                android:shadowDy="3"/>


            <LinearLayout
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:orientation="vertical"
                android:layout_marginTop="224dp"
                android:layout_marginStart="46dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/typeName1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="typeName"
                    android:textColor="#FF4048"
                    android:textSize="11dp"/>

                <TextView
                    android:id="@+id/spareLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="标签"
                    android:textStyle="bold"
                    android:textColor="#FF4048"
                    android:textSize="18dp"/>


            </LinearLayout>


            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="85dp"
                android:orientation="vertical"
                android:layout_marginTop="212dp"
                android:layout_marginStart="146dp"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/typeName2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="typeName"
                    android:textColor="#FF4048"
                    android:textSize="11dp"
                    android:layout_marginTop="12dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="1dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¥"
                        android:textColor="#FF4048"
                        android:textSize="14dp"/>

                    <TextView
                        android:id="@+id/price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="99"
                        android:textColor="#FF4048"
                        android:includeFontPadding="false"
                        android:layout_marginStart="3dp"
                        android:textStyle="bold"
                        android:textSize="28dp"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/bottomLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="bottomLabel"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/white"
                    android:textSize="11dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/submit"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text=""
                android:gravity="center"
                android:textSize="18dp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginHorizontal="40dp"
                android:layout_marginTop="310dp"
                android:shadowRadius="3"
                android:shadowColor="#4D6D1004"
                android:shadowDx="3"
                android:shadowDy="3"/>


            <TextView
                android:id="@+id/dingyueshuoming"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="360dp"
                android:gravity="center"
                android:text=""
                android:textSize="11dp"
                android:textColor="#926F30"/>

        </RelativeLayout>


        <LinearLayout
            android:id="@+id/checkboxLayout1"
            android:layout_width="wrap_content"

            android:layout_gravity="center_horizontal"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/payCheckBox"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:padding="2dp"
                android:src="@mipmap/business_checkbox_on" />

            <TextView
                android:id="@+id/permissionTipsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="阅读并勾选"
                android:textColor="#B8B8B8"
                android:textSize="11dp" />

            <TextView
                android:id="@+id/left_click"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="《用户协议》"
                android:textColor="#B8B8B8"
                android:textSize="11dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/center_click"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="《隐私政策》"
                android:textColor="#B8B8B8"
                android:textSize="11dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/right_click"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="《付费协议》"
                android:textColor="#B8B8B8"
                android:textSize="11dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/last_click"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="《自动续费协议》"
                android:textColor="#B8B8B8"
                android:textSize="11dp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>
</RelativeLayout>