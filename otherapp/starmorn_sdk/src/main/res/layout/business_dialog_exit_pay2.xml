<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <LinearLayout
        android:id="@+id/outRootLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center">

        <RelativeLayout
            android:id="@+id/rootLayout"
            android:layout_width="285dp"
            android:layout_height="472dp">

            <ImageView
                android:id="@+id/loadImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>

            <TextView
                android:id="@+id/bottomLabel1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="底层标签底层标签底层标签"
                android:textColor="#782E00"
                android:textSize="12dp"
                android:textStyle="bold"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="2dp"
                android:layout_above="@+id/timeLayout"/>

            <LinearLayout
                android:id="@+id/timeLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="5dp"
                android:layout_above="@+id/submit">

                <TextView
                    android:id="@+id/topLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="顶层标签"
                    android:textColor="#782E00"
                    android:textSize="12dp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/timeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_marginStart="4dp"
                    android:text="00:00:00:00"
                    android:textColor="#FF3B00"
                    android:textSize="15dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/submit"
                android:layout_width="250dp"
                android:layout_height="50dp"
                android:layout_centerHorizontal="true"
                android:background="@drawable/business_exit_pay_2_dialog_submit"
                android:gravity="center"
                android:text="按钮文字"
                android:layout_above="@+id/closeBtn"
                android:textColor="#FEF4EC"
                android:textSize="16dp"
                android:textStyle="bold" />


            <TextView
                android:id="@+id/closeBtn"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:text="以后原价购买"
                android:gravity="center"
                android:layout_centerHorizontal="true"
                android:layout_alignParentBottom="true"
                android:visibility="invisible"
                android:textColor="#B69F90" />

        </RelativeLayout>


        <LinearLayout
            android:id="@+id/checkboxLayout1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/rootLayout"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/payCheckBox"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:padding="2dp"
                android:src="@mipmap/business_checkbox_on" />

            <TextView
                android:id="@+id/permissionTipsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="阅读并勾选"
                android:textColor="#B8B8B8"
                android:textSize="11dp" />

            <TextView
                android:id="@+id/left_click"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="《用户协议》"
                android:textColor="#B8B8B8"
                android:textSize="11dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/center_click"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="《隐私政策》"
                android:textColor="#B8B8B8"
                android:textSize="11dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/right_click"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="《付费协议》"
                android:textColor="#B8B8B8"
                android:textSize="11dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/last_click"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="《自动续费协议》"
                android:textColor="#B8B8B8"
                android:textSize="11dp"
                android:textStyle="bold" />

        </LinearLayout>


    </LinearLayout>


</RelativeLayout>