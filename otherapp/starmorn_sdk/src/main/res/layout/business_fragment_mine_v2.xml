<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7F7"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/topLayout"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:scaleType="centerCrop"
        android:src="@mipmap/business_mine_page_top_image_v2" />

    <LinearLayout
        android:id="@+id/userInfoLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/userInfoGotoImg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="10dp"
                android:src="@mipmap/business_mine_goto2_v2" />
        </RelativeLayout>

        <ImageView
            android:id="@+id/userIcon"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginTop="-20dp"
            android:scaleType="centerCrop"
            android:src="@mipmap/business_def_user_icon" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/userName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:text="点击登录"
                android:textColor="#1A1A1A"
                android:textSize="14dp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <RelativeLayout
        android:id="@+id/vipBannerLayout"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_below="@+id/topLayout"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="-80dp"
        android:background="@mipmap/business_vip_banner_v2">

        <ImageView
            android:id="@+id/vipBannerLogo"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginStart="5dp"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@+id/vipBannerLogo"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/paddingView"
                android:layout_width="15dp"
                android:layout_height="0dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/vipBannerTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/pay_banner"
                    android:maxLines="1"
                    android:text="成为超级会员 "
                    android:textColor="#4E1C00"
                    android:textSize="23dp"
                    android:textStyle="italic" />

                <TextView
                    android:id="@+id/vipBannerDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="开通会员专享全部资源"
                    android:textColor="#4E1C00"
                    android:textSize="12dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/vipBannerBtn"
                android:layout_width="85dp"
                android:layout_height="39dp"
                android:layout_marginEnd="15dp"
                android:background="@drawable/business_vip_pay_btn_bg"
                android:gravity="center"
                android:text="立即开通"
                android:textColor="#FFFFFF"
                android:textSize="13dp" />
        </LinearLayout>

    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/vipBannerLayout"
        android:layout_marginTop="10dp"
        android:paddingBottom="20dp"
        android:orientation="vertical"
        android:layout_marginHorizontal="12dp">

        <androidx.constraintlayout.utils.widget.ImageFilterView
            android:id="@+id/minePageSettingsBack"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_alignBottom="@+id/settings"
            app:round="12dp"
            android:background="@color/white"/>

        <LinearLayout
            android:id="@+id/settingsListTipsLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_margin="20dp">

            <View
                android:id="@+id/minePageSettingsTitleMark"
                android:layout_width="4dp"
                android:layout_height="16dp"
                android:background="#1B8EFF"/>

            <TextView
                android:id="@+id/minePageSettingsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="精选服务"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="15dp"
                android:layout_marginStart="5dp"/>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:itemCount="5"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:layout_below="@+id/settingsListTipsLayout"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="3"
            android:paddingBottom="20dp"
            tools:listitem="@layout/business_item_mine_settings_layout_v2" />

    </RelativeLayout>

</RelativeLayout>