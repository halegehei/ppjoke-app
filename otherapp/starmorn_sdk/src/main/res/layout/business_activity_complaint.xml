<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF">

    <RelativeLayout
        android:id="@+id/title_layout"
        android:layout_width="match_parent"
        android:layout_height="80dp">

        <ImageView
            android:id="@+id/returnBtnV"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_alignParentBottom="true"
            android:padding="8dp"
            android:src="@mipmap/business_return_black_btn" />

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:gravity="center"
            android:text="投诉举报"
            android:textColor="#000000"
            android:textSize="17dp"
            android:textStyle="bold" />

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/messageType"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="10dp"
        android:layout_marginHorizontal="15dp"
        android:layout_below="@+id/title_layout"
        android:orientation="horizontal"
        android:background="@drawable/business_feedback_edit_bg"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/editV1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/messageType"
            android:layout_marginHorizontal="5dp"
            android:background="@drawable/business_feedback_edit_bg"
            android:gravity="left"
            android:hint="请输入问题标题（不可超过20字）"
            android:maxLines="1"
            android:maxLength="20"
            android:inputType="text"
            android:padding="15dp"
            android:textColor="#000000"
            android:textColorHint="#5B606A"
            android:textSize="14dp" />

    </LinearLayout>

    <EditText
        android:id="@+id/editV"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_below="@+id/messageType"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/business_feedback_edit_bg"
        android:gravity="left"
        android:hint="请输入您的举报内容，我们将尽快解决～（不可超过100字）"
        android:inputType="textMultiLine"
        android:padding="15dp"
        android:maxLength="100"
        android:textColor="#000000"
        android:textColorHint="#5B606A"
        android:textSize="14dp" />


    <TextView
        android:id="@+id/feedTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="联系方式（必填）"
        android:layout_marginStart="12dp"
        android:layout_marginTop="20dp"
        android:textColor="#000000"
        android:layout_below="@+id/editV"
        android:textSize="16dp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/phoneEdit"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@+id/feedTitle"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/business_feedback_edit_bg"
        android:gravity="left"
        android:hint="请输入您的手机号/邮箱"
        android:maxLength="11"
        android:maxLines="1"
        android:textColorHint="#5B606A"
        android:padding="15dp"
        android:textColor="#000000"
        android:textSize="14dp" />

    <TextView
        android:id="@+id/submit"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="30dp"
        android:layout_marginHorizontal="15dp"
        android:background="@drawable/default_btn_bg"
        android:gravity="center"
        android:text="发送"
        android:textColor="#FFFFFF"
        android:textSize="15dp"
        android:textStyle="bold" />


</RelativeLayout>