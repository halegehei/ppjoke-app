<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF">

    <RelativeLayout
        android:id="@+id/title_layout"
        android:layout_width="match_parent"
        android:layout_height="80dp">

        <ImageView
            android:id="@+id/returnBtnV"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_alignParentBottom="true"
            android:padding="8dp"
            android:src="@mipmap/business_return_black_btn" />

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:gravity="center"
            android:text="用户反馈"
            android:textColor="#000000"
            android:textSize="17dp"
            android:textStyle="bold" />

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/messageType"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="10dp"
        android:layout_marginHorizontal="15dp"
        android:layout_below="@+id/title_layout"
        android:orientation="horizontal"
        android:background="@drawable/business_feedback_edit_bg"
        android:gravity="center_vertical"
        android:paddingHorizontal="10dp">

        <TextView
            android:id="@+id/feedbackType"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="请选择反馈类型"
            android:textColor="#000000"
            android:textSize="15dp"/>

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:rotation="180"
            android:src="@mipmap/business_list_item_push_icon"/>


    </LinearLayout>

    <EditText
        android:id="@+id/editV"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_below="@+id/messageType"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/business_feedback_edit_bg"
        android:gravity="left"
        android:hint="请输入您的反馈～～"
        android:maxLines="1"
        android:maxLength="11"
        android:inputType="text"
        android:padding="15dp"
        android:textColor="#000000"
        android:textColorHint="#5B606A"
        android:textSize="14dp" />


    <TextView
        android:id="@+id/feedTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="联系方式"
        android:layout_marginStart="12dp"
        android:layout_marginTop="20dp"
        android:textColor="#000000"
        android:layout_below="@+id/editV"
        android:textSize="16dp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/phoneEdit"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@+id/feedTitle"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/business_feedback_edit_bg"
        android:gravity="left"
        android:hint="请输入您的手机号"
        android:maxLength="11"
        android:maxLines="1"
        android:inputType="phone"
        android:textColorHint="#5B606A"
        android:padding="15dp"
        android:textColor="#000000"
        android:textSize="14dp" />

    <TextView
        android:id="@+id/submit"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="30dp"
        android:layout_marginHorizontal="15dp"
        android:background="@drawable/default_btn_bg"
        android:gravity="center"
        android:text="提交"
        android:textColor="#FFFFFF"
        android:textSize="15dp"
        android:textStyle="bold" />


</RelativeLayout>