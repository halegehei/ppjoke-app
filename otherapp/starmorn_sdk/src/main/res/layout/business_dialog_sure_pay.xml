<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_marginHorizontal="30dp"
        android:background="@drawable/business_default_dialog_bg_white"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:text="支付提示"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:textSize="18dp" />

        <TextView
            android:id="@+id/text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="15dp"
            android:text="订阅说明文案订阅说明文案订阅说明文案订阅说明文案订阅说明文案订阅说明文案"
            android:textColor="#666666"
            android:textSize="15dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/cancel"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:background="@drawable/business_pay_sure_dialog_cancel_btn_bg"
                android:gravity="center"
                android:maxLines="1"
                android:text="取消"
                android:textColor="@color/business_dialog_theme_cancel_btn_text_color" />

            <TextView
                android:id="@+id/submit"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/default_btn_bg"
                android:gravity="center"
                android:maxLines="1"
                android:text="确认"
                android:textColor="@color/business_dialog_theme_submit_btn_text_color"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>