<?xml version="1.0" encoding="UTF-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="0dp"
                android:color="#4CAF50"/>
            <gradient
                android:angle="0"
                android:startColor="#E9E9E9"
                android:endColor="#E9E9E9"
                />
            <corners
                android:radius="12dp"/>

            <padding
                android:top="2dp"
                android:bottom="2dp"
                android:left="2dp"
                android:right="2dp"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="0dp"
                android:color="#4CAF50"/>
            <gradient
                android:angle="0"
                android:startColor="#F8F8F8"
                android:endColor="#F8F8F8"
               />
            <corners
                android:radius="12dp"/>

        </shape>
    </item>

</layer-list>

