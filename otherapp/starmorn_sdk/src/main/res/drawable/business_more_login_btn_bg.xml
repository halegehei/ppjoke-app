<?xml version="1.0" encoding="UTF-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#D0D0D0"/>
            <gradient
                android:angle="0"
                android:startColor="#FFFFFF"
                android:endColor="#FFFFFF"
               />
            <corners
                android:radius="30dp"/>
        </shape>
    </item>
</layer-list>

