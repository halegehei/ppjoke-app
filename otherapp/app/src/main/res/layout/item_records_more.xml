<com.mcxtzhang.swipemenulib.SwipeMenuLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:layout_marginHorizontal="14dp"
    android:background="#FCFCFC"
    android:clickable="true"
    >
    <!-- 左侧的图片 -->

    <LinearLayout


        android:id="@+id/item_swipe_content"
        android:layout_width="match_parent"
        android:paddingLeft="13dp"
        android:background="#FCFCFC"
        android:layout_height="80dp"
        android:orientation="horizontal"
        >

        <ImageView
            android:id="@+id/iv_phone_image"
            android:layout_width="42dp"
            android:layout_height="52dp"
            android:src="@mipmap/icon_phone"
            android:layout_gravity="center_vertical"
            android:scaleType="centerCrop"
            android:layout_marginLeft="13dp"
            android:layout_marginEnd="15dp"/>

        <!-- 中间的文本部分 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_phone_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="手机名称"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <View
                android:layout_width="wrap_content"
                android:layout_weight="1"
                android:layout_height="0dp"/>

            <TextView
                android:id="@+id/tv_phone_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="123456789"
                android:textColor="#999999"
                android:textSize="14sp"/>
        </LinearLayout>

<!--        <LinearLayout-->
<!--            android:id="@+id/item_swipe_button"-->
<!--            android:layout_width="50dp"-->
<!--            android:layout_marginRight="50dp"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:orientation="horizontal"-->
<!--            >-->
<!--            <ImageView-->
<!--                android:id="@+id/iv_edit"-->
<!--                android:layout_width="38dp"-->
<!--                android:layout_height="46dp"-->
<!--                android:src="@mipmap/ic_share_eye"-->
<!--                android:scaleType="centerCrop"-->
<!--                android:layout_marginEnd="15dp"/>-->

<!--            <ImageView-->
<!--                android:id="@+id/iv_del"-->
<!--                android:layout_width="38dp"-->
<!--                android:layout_height="46dp"-->
<!--                android:src="@mipmap/ic_right_qrcode"-->
<!--                android:scaleType="centerCrop"-->
<!--                android:layout_marginEnd="15dp"/>-->


<!--        </LinearLayout>-->

        <!-- 右侧的图标 -->
        <ImageView
            android:id="@+id/iv_arrow"
            android:layout_width="19dp"
            android:layout_height="19dp"
            android:layout_marginRight="7dp"
            android:layout_gravity="center_vertical"
            android:src="@mipmap/ic_item_right"
            android:contentDescription="Arrow"/>

    </LinearLayout>




    <LinearLayout
        android:layout_width="160dp"
        android:layout_height="80dp"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="80dp"
            >

            <ImageView
                android:id="@+id/iv_edit"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:scaleType="fitXY"
                android:layout_gravity="center"
                android:src="@mipmap/ic_item_add" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="80dp"
            >

            <ImageView
                android:id="@+id/iv_del"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:scaleType="fitXY"
                android:src="@mipmap/ic_item_del" />


        </FrameLayout>
    </LinearLayout>







</com.mcxtzhang.swipemenulib.SwipeMenuLayout>

