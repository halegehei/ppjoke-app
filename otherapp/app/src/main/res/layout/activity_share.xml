<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#f7f7f7">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#f7f7f7"
            android:orientation="vertical">

            <RelativeLayout

                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                >

                <ImageView

                    android:layout_width="match_parent"
                    android:layout_height="334dp"
                    android:src="@mipmap/home_lj_bg"
                    android:scaleType="fitXY"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true" />

                <TextView

                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="同屏共享"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="48dp"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:layout_centerHorizontal="true"
                    android:layout_alignParentTop="true" />
                <ImageView
                    android:id="@+id/backButton"
                    android:layout_marginTop="60dp"
                    android:layout_marginLeft="15dp"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@mipmap/icon_back"


                    />


                <ImageView
                    android:id="@+id/iv_qrcode"
                    android:layout_alignParentRight="true"
                    android:layout_marginTop="60dp"
                    android:layout_marginRight="13dp"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@mipmap/icon_tpgx_qrcode"
                    />


            </RelativeLayout>





            <LinearLayout

                android:id="@+id/l3"
                android:visibility="gone"
                android:layout_marginTop="-26dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout

                    android:layout_width="match_parent"
                    android:layout_height="411dp"

                    android:orientation="vertical"

                    android:layout_marginLeft="13dp"
                    android:layout_marginRight="13dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/rounded_background">




                    <ImageView
                        android:layout_width="186dp"
                        android:layout_height="186dp"
                        android:src="@mipmap/ic_share_connecting"
                        android:layout_gravity="center_horizontal"

                        />

                    <TextView

                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:layout_gravity="center_horizontal"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:layout_marginTop="20dp"
                        android:text="已开启同屏共享"
                        />


                    <RelativeLayout


                        android:layout_marginTop="35dp"
                        android:layout_gravity="center_horizontal"

                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">




                        <!-- Microphone Icon -->
                        <ImageView
                            android:id="@+id/microphone_icon"
                            android:layout_width="89dp"
                            android:layout_height="89dp"
                            android:src="@mipmap/icon_mic_on"
                            android:layout_centerInParent="true"/>
                    </RelativeLayout>


                </LinearLayout>


                <TextView
                    android:id="@+id/tv_close"
                    android:text="结束投屏"
                    android:textSize="15sp"
                    android:padding="20dp"
                    android:layout_marginTop="10dp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>



            </LinearLayout>









            <LinearLayout
                android:id="@+id/l1"
                android:layout_width="match_parent"
                android:layout_height="145dp"
                android:orientation="vertical"
                android:layout_marginTop="-26dp"
                android:layout_marginLeft="13dp"
                android:layout_marginRight="13dp"

                android:background="@drawable/rounded_background">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_background"
                    android:paddingHorizontal="10dp"
                    >

                    <TextView
                        android:id="@+id/text_device_code"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="设备码"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:textSize="15sp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="18dp"/>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="53dp"
                        android:layout_toEndOf="@id/text_device_code"
                        android:layout_toStartOf="@id/iv_copy"
                        android:background="@drawable/edit_background"
                        android:padding="12dp"
                        tools:ignore="NotSibling">

                        <EditText
                            android:id="@+id/et_device_code"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:hint="输入设备码"
                            android:text="423413215345224"
                            android:textColor="#333333"
                            android:textSize="15sp"

                            android:maxLines="1"
                            android:inputType="text"
                            android:drawablePadding="10dp"
                            android:paddingEnd="40dp"/>

                        <ImageView
                            android:id="@+id/iv_copy"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="end|center_vertical"
                            android:src="@mipmap/ic_share_copy"
                            android:padding="10dp"
                            android:contentDescription="Copy"/>

                    </FrameLayout>

                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_background"
                    android:paddingHorizontal="10dp"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/text_verification_code"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="验证码"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:textSize="16sp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="18dp"/>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="53dp"
                        android:layout_toEndOf="@id/text_verification_code"
                        android:background="@drawable/edit_background"
                        android:padding="12dp"
                        >

                        <EditText
                            android:id="@+id/et_verification_code"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:drawablePadding="10dp"
                            android:hint="输入验证码"

                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:minHeight="48dp"
                            android:text="324123"
                            android:textColor="#333333"
                            android:textSize="15sp" />

                        <ImageView
                            android:id="@+id/iv_view"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="end|center_vertical"
                            android:src="@mipmap/ic_share_eye_close"
                            android:padding="10dp"
                            android:contentDescription="View"/>

                    </FrameLayout>

                </RelativeLayout>

            </LinearLayout>


            <LinearLayout

                android:id="@+id/l2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout

                    android:layout_width="match_parent"
                    android:layout_height="116dp"
                    android:orientation="vertical"
                    android:layout_margin="13dp"
                    android:background="@drawable/rounded_background"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="验证码设置"
                            android:layout_marginLeft="13dp"
                            android:layout_marginTop="18dp"
                            android:textColor="#000000"

                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"/>

                        <ImageView
                            android:id="@+id/iv_query"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginRight="10dp"
                            android:src="@mipmap/ic_share_query"
                            android:contentDescription="Help"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_marginTop="15dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"

                        android:background="@drawable/rounded_background"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/never_refresh"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="37dp"
                            android:textColor="#000000"
                            android:text="从不刷新"
                            android:background="@drawable/rounded_button_background"
                            android:gravity="center"
                            android:textSize="13sp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/refresh_on_end"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="37dp"

                            android:text="投屏结束刷新"

                            android:textColor="#000000"
                            android:background="@drawable/rounded_button_background_select"
                            android:gravity="center"
                            android:textSize="13sp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/refresh_daily"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="37dp"

                            android:text="每天刷新"
                            android:textColor="#000000"
                            android:background="@drawable/rounded_button_background"
                            android:gravity="center"
                            android:textSize="13sp"/>
                    </LinearLayout>

                </LinearLayout>


                <Button

                    android:id="@+id/connectButton"
                    android:layout_width="193dp"
                    android:layout_height="48dp"
                    android:text="开始投屏"
                    android:background="@drawable/default_btn_bg"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="90dp"/>




            </LinearLayout>


        </LinearLayout>

    </ScrollView>





        <!-- Start Button -->


</LinearLayout>